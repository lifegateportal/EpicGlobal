# 1. THE MAIN FRONTEND
epicglobal.app {
    # This points to wherever your main dashboard is running
    # If it's a static build, we use 'file_server'. 
    # If it's running on a port, use 'reverse_proxy'.
    reverse_proxy localhost:3000 
    
    # Compress responses to save bandwidth on mobile
    encode gzip zstd
}

# 2. THE ORCHESTRATOR API (The Remote Control)
api.epicglobal.app {
    reverse_proxy localhost:4000
    
    # Headers to ensure smooth communication with the iPad
    header {
        Access-Control-Allow-Origin https://epicglobal.app
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type"
    }
}

# 3. WILDCARD FOR YOUR PROJECTS (Optional but powerful)
# This allows any project you launch to get a subdomain automatically
# e.g. alpha-test.epicglobal.app
*.epicglobal.app {
    # This requires DNS validation, we can set this up later if needed.
}